# Firebase Firestore credentials for the attack adaptation notebooks.
# Copy this file to `.env` in this folder and fill in ONE auth option below.
# The notebooks load this file automatically (via python-dotenv) before any
# Firestore call. `.env` and service-account JSON files are gitignored.

# ----------------------------------------------------------------------------
# AUTH — choose exactly ONE of the two options.
# ----------------------------------------------------------------------------

# Option A (recommended for local use): path to the service-account JSON file.
# Download it from Firebase Console > Project Settings > Service accounts >
# "Generate new private key". Keep the JSON file OUTSIDE the repo.
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/firebase-service-account.json

# Option B (good for CI / notebook secrets): the full service-account JSON as a
# single-line string. Leave Option A blank if you use this.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"...","token_uri":"https://oauth2.googleapis.com/token"}

# ----------------------------------------------------------------------------
# OPTIONAL
# ----------------------------------------------------------------------------

# Only needed if the project id cannot be inferred from the credentials above.
# FIREBASE_PROJECT_ID=your-firebase-project-id

# ----------------------------------------------------------------------------
# GPU SELECTION
# ----------------------------------------------------------------------------

# Pin the notebook to a single GPU to avoid OOM on a shared multi-GPU box.
# The first cell reads this before CUDA initializes; the chosen physical GPU
# appears as cuda:0 in the process (and in the Flower/Ray workers).
#   - Set an index (e.g. 1) to force a specific GPU.
#   - Set "cpu" to force CPU.
#   - Leave unset to auto-pick the GPU with the most free memory.
# EXPERIMENT_GPU=1

# ----------------------------------------------------------------------------
# HUGGING FACE
# ----------------------------------------------------------------------------

# User access token from https://huggingface.co/settings/tokens .
# Required only for gated/private models; public checkpoints work without it.
# huggingface_hub and transformers read HF_TOKEN automatically once loaded.
HF_TOKEN=hf_your_access_token_here
